{
  "version": 2,
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "installCommand": "npm install",
      "buildCommand": "npm run build"
    },
    "backend": {
      "root": "backend",
      "framework": "express",
      "entrypoint": "server.js",
      "installCommand": "npm install",
      "devCommand": "npm run dev"
    }
  }
}
